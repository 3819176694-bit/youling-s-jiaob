local originalAtmosphere = nil
local originalFogEnd = 0

local function toggleVisionMode(enabled)
    if enabled then
        originalAtmosphere = Lighting:FindFirstChild("Atmosphere")
        originalFogEnd = Lighting.FogEnd
        Lighting.Brightness = 0.06
        Lighting.Ambient = Color3.new(0.33, 0.74, 0.35)
        if originalAtmosphere then originalAtmosphere.Parent = nil end
        Lighting.FogEnd = 666666
        Lighting.ColorShift_Top = Color3.new(0.22, 0.54, 0.23)
        Lighting.ColorShift_Bottom = Color3.new(0.26, 0.57, 0.28)
    else
        Lighting.Brightness = 2
        Lighting.Ambient = Color3.new(1,1,1)
        if originalAtmosphere then originalAtmosphere.Parent = Lighting end
        if originalFogEnd > 0 then Lighting.FogEnd = originalFogEnd end
        Lighting.ColorShift_Top = Color3.new(0,0,0)
        Lighting.ColorShift_Bottom = Color3.new(0,0,0)
    end
end

-- ==================== 9. 自动跳 ====================
local gameJumpFunction = nil
local isJumping = false

P.CharacterAdded:Connect(function(newChar)
    char = newChar
    humanoid = newChar:WaitForChild("Humanoid")
end)

local function findGameJumpLogic()
    local potentialTargets = {
        game.ReplicatedStorage:FindFirstChild("Remotes"),
        game:GetService("StarterPlayer").StarterPlayerScripts,
        _G
    }
    for _, target in ipairs(potentialTargets) do
        if target then
            for _, obj in pairs(target:GetDescendants()) do
                if obj:IsA("RemoteEvent") and (string.find(obj.Name, "Jump") or string.find(obj.Name, "Bunny")) then
                    gameJumpFunction = function()
                        pcall(function() obj:FireServer() end)
                    end
                    return
                end
            end
        end
    end
end
findGameJumpLogic()

local function performJump()
    if gameJumpFunction then
        gameJumpFunction()
    else
        if humanoid:GetState() == Enum.HumanoidStateType.Freefall or
           humanoid:GetState() == Enum.HumanoidStateType.Jumping then return end
        pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end)
    end
end

RunService.Heartbeat:Connect(function()
    if not _G[S].AJ then return end
    if not humanoid then return end
    local isGrounded = humanoid.FloorMaterial ~= Enum.Material.Air
    if isGrounded then isJumping = false end
    if not isJumping and isGrounded then
        performJump()
        isJumping = true
    end
end)

