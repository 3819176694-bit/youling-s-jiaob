        TimeGui.Enabled = _G[S].ShowTime
        return
    end

    TimeGui = Instance.new("ScreenGui")
    TimeGui.Name = "TimeDisplayGUI"
    TimeGui.ResetOnSpawn = false
    TimeGui.Parent = PG
    TimeGui.Enabled = _G[S].ShowTime

    local Frame = Instance.new("Frame")
    Frame.Name = "TimeFrame"
    Frame.Size = UDim2.new(0, 185, 0, 46)
    Frame.Position = UDim2.new(0, 12, 1, -62)
    Frame.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    Frame.BackgroundTransparency = 0.03
    Frame.BorderSizePixel = 0
    Frame.Parent = TimeGui
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 12)

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color3.fromRGB(158, 198, 172)
    Stroke.Thickness = 1.8
    Stroke.Transparency = 0.47
    Stroke.Parent = Frame

    TimeLabel = Instance.new("TextLabel")
    TimeLabel.Name = "TimeLabel"
    TimeLabel.Size = UDim2.new(1, -10, 1, 0)
    TimeLabel.Position = UDim2.new(0, 5, 0, 0)
    TimeLabel.BackgroundTransparency = 1
    TimeLabel.Text = "0"
    TimeLabel.TextColor3 = Color3.fromRGB(192, 228, 208)
    TimeLabel.TextSize = 30
    TimeLabel.Font = Enum.Font.GothamBold
    TimeLabel.TextXAlignment = Enum.TextXAlignment.Center
    TimeLabel.Parent = Frame
end

local function UpdateTimeDisplay()
    if not _G[S].ShowTime then
        if TimeGui then TimeGui.Enabled = false end
        return
    end

    if not TimeGui or not TimeGui.Parent then
        CreateTimeDisplay()
    end

    TimeGui.Enabled = true

    -- 从指定路径获取时间：ReplicatedStorage/Values/currentTime
    local currentTime = 0
    local valuesFolder = ReplicatedStorage:FindFirstChild("Values")
    if valuesFolder then
        local currentTimeObject = valuesFolder:FindFirstChild("currentTime")
        if currentTimeObject and currentTimeObject:IsA("NumberValue") then
            currentTime = currentTimeObject.Value
        end
    end

    if TimeLabel then
        TimeLabel.Text = tostring(math.floor(currentTime))
    end
end

task.spawn(function()
    while _G[S].Running do
        pcall(UpdateTimeDisplay)
        task.wait(1)
    end
end)

