local function ModWeap()
    local c=0
    local function p(t) if t:IsA("Tool") and t:GetAttribute("Swingrate")~=nil then t:SetAttribute("Swingrate",-1) c+=1 end end
    for _,t in ipairs(backpack:GetChildren()) do p(t) end
    for _,t in ipairs(char:GetChildren()) do p(t) end
    return c
end
local function CleanJunk()
    local c=0
    local ji={"Orb of Shadow","Orb of Thunder","Orb of Rain","Orb of Wind","Vitamins","Damaged Stun Stick"}
    local function p(i) if i:IsA("Tool") then for _,n in ipairs(ji) do if i.Name==n then i:Destroy() c+=1 break end end end end
    for _,i in ipairs(backpack:GetChildren()) do p(i) end
    for _,i in ipairs(char:GetChildren()) do p(i) end
    return c
end
