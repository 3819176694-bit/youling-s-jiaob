-- ==================== 7. 无限体力 ====================
local staminaConnection = nil
local staminaInstance = nil

local function findStamina()
    local modules = ReplicatedStorage:FindFirstChild("Modules")
    if not modules then return nil end
    local uibased = modules:FindFirstChild("UIbased")
    if not uibased then return nil end
    local staminaFolder = uibased:FindFirstChild("Stamina")
    if not staminaFolder then return nil end
    local staminaObj = staminaFolder:FindFirstChild("Stamina")
    if staminaObj and (staminaObj:IsA("NumberValue") or staminaObj:IsA("IntValue")) then
        return staminaObj
    end
    return nil
end

local function setInfiniteStamina(enabled)
    if enabled then
        if not staminaInstance then staminaInstance = findStamina() end
        if staminaInstance then
            if staminaConnection then staminaConnection:Disconnect() end
            staminaConnection = RunService.Heartbeat:Connect(function()
                if _G[S].Stamina and staminaInstance then
                    staminaInstance.Value = 99
                end
            end)
        end
    else
        if staminaConnection then staminaConnection:Disconnect(); staminaConnection = nil end
    end
end

