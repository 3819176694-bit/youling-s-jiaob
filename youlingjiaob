-- ==================== 5. 废料 / 天气球透视核心 ====================
local function ProcessScraps()
    if not _G[S].A then return end
    local F = workspace:FindFirstChild("Storage") and workspace.Storage:FindFirstChild("Map") and workspace.Storage.Map:FindFirstChild("Scraps")
    if not F then return end

    for _, M in pairs(F:GetChildren()) do
        if M:IsA("Model") then
            local Match = GetMatch(M)
            if Match then
                local isOrb = Match.IsOrb
                local shouldShow = false

                if isOrb then
                    if _G[S].F_Orb then
                        if _G[S].Filter_Orb then
                            local RareNames = {"AURORA", "DREAMS", "SHADOW", "THE SEA", "THE SUN"}
                            if table.find(RareNames, Match.L) then
                                shouldShow = true
                            end
                        else
                            shouldShow = true
                        end
                    end
                else
                    if _G[S].F_Scrap then
                        if _G[S].Filter_Scrap and (Match.N=="Metal" or Match.N=="Rusty" or Match.N=="Drenched") then
                            shouldShow = false
                        else
                            shouldShow = true
                        end
                    end
                end

                if shouldShow then
                    local BasePart = M:FindFirstChildWhichIsA("BasePart")
                    if BasePart then
                        local B = M:FindFirstChild("B_"..S)
                        if not B then
                            B = Instance.new("BillboardGui")
                            B.Name = "B_"..S
                            B.Size = UDim2.new(0, 95, 0, 34)
                            B.StudsOffset = Vector3.new(0, 3, 0)
                            B.AlwaysOnTop = true
                            B.Adornee = BasePart
                            B.Parent = M
                            local L = Instance.new("TextLabel")
                            L.Size = UDim2.new(1,0,1,0)
                            L.BackgroundTransparency = 1
                            L.Text = Match.L or Match.N
                            L.TextColor3 = Match.C
                            L.TextStrokeTransparency = 0.2
                            L.Font = Enum.Font.GothamBold
                            L.TextSize = 20
                            L.Parent = B
                        end
                    end
                else
                    local B = M:FindFirstChild("B_"..S)
                    if B then B:Destroy() end
                end
            end
        end
    end
end

