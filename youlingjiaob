local customWeaponInput = ""

-- 武器修改函数 - 支持所有武器
local function modifyAllWeapons()
    local count = 0
    
    local function processTool(tool)
        if tool:IsA("Tool") then
            local toolName = tool.Name
            
            -- 将所有武器的冷却时间设置为-1（无冷却）
            if tool:GetAttribute("Swingrate") ~= nil then
                tool:SetAttribute("Swingrate", -1)
                count = count + 1
            end
        end
    end
    
    -- 扫描背包和角色身上的道具
    for _, tool in ipairs(backpack:GetChildren()) do processTool(tool) end
    for _, tool in ipairs(char:GetChildren()) do processTool(tool) end
    
    return count
end

-- 清理垃圾道具函数
local function cleanJunkItems()
    local count = 0
    local junkItems = {
        "Orb of Shadow", "Orb of Thunder", "Orb of Rain", 
        "Orb of Wind", "Vitamins", "Damaged Stun Stick"
    }
    
    local function checkAndDestroy(item)
        if item:IsA("Tool") then
            for _, junkName in ipairs(junkItems) do
                if item.Name == junkName then
                    item:Destroy()
                    count = count + 1
                    break
                end
            end
        end
    end
    
    for _, item in ipairs(backpack:GetChildren()) do checkAndDestroy(item) end
    for _, item in ipairs(char:GetChildren()) do checkAndDestroy(item) end
    
    return count
end

