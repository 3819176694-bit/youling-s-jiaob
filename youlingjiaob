local function GetMatch(m) for _,c in ipairs(ScrapConfig) do if m.Name:find(c.N) then return c end end end

local function ProcessScraps()
    if not _G[S].A then return end
    local F = workspace:FindFirstChild("Storage") and workspace.Storage:FindFirstChild("Map") and workspace.Storage.Map:FindFirstChild("Scraps")
    if not F then return end
    if _G[S].GiftESP then
        local function Scan(parent)
            for _,ch in ipairs(parent:GetChildren()) do
                if ch:IsA("Part") and string.sub(ch.Name,-4)=="Gift" then
                    if not ch:FindFirstChild("B_Gift_"..S) then
                        local B = Instance.new("BillboardGui")
                        B.Name="B_Gift_"..S; B.Size=UDim2.new(0,120,0,40); B.StudsOffset=Vector3.new(0,3,0)
                        B.AlwaysOnTop=true; B.Adornee=ch; B.Parent=ch
                        local L=Instance.new("TextLabel")
                        L.Size=UDim2.new(1,0,1,0); L.BackgroundTransparency=1
                        L.Text="🎁 "..ch.Name; L.TextColor3=Color3.fromRGB(255,215,0)
                        L.TextStrokeTransparency=0.2; L.Font=Enum.Font.GothamBold; L.TextSize=18; L.Parent=B
                    end
                elseif not ch:IsA("BasePart") then
                    Scan(ch)
                end
            end
        end
        Scan(F)
    else
        local function Cl(parent)
            for _,ch in ipairs(parent:GetChildren()) do
                local b=ch:FindFirstChild("B_Gift_"..S); if b then b:Destroy() end
                if not ch:IsA("BasePart") then Cl(ch) end
            end
        end; Cl(F)
    end
    for _,M in ipairs(F:GetChildren()) do
        if M:IsA("Model") then
            local mt=GetMatch(M); if not mt then continue end
            local isOrb=mt.IsOrb; local show=false
            if isOrb then
                if _G[S].F_Orb then
                    if _G[S].Filter_Orb then
                        local r={"AURORA","DREAMS","SHADOW","THE SEA","THE SUN"}
                        if table.find(r,mt.L) then show=true end
                    else show=true end
                end
            else
                if _G[S].F_Scrap then
                    if _G[S].Filter_Scrap and (mt.N=="Metal" or mt.N=="Rusty" or mt.N=="Drenched") then show=false else show=true end
                end
            end
            if show then
                local bp=M:FindFirstChildWhichIsA("BasePart")
                if bp and not M:FindFirstChild("B_"..S) then
                    local B=Instance.new("BillboardGui")
                    B.Name="B_"..S;B.Size=UDim2.new(0,95,0,34);B.StudsOffset=Vector3.new(0,3,0)
                    B.AlwaysOnTop=true;B.Adornee=bp;B.Parent=M
                    local L=Instance.new("TextLabel")
                    L.Size=UDim2.new(1,0,1,0);L.BackgroundTransparency=1
                    L.Text=mt.L or mt.N;L.TextColor3=mt.C
                    L.TextStrokeTransparency=0.2;L.Font=Enum.Font.GothamBold;L.TextSize=20;L.Parent=B
                end
            else
                local b=M:FindFirstChild("B_"..S);if b then b:Destroy() end
            end
        end
    end
end

local EP = workspace:FindFirstChild("Entities") or workspace
local DistC = {{450,Color3.fromHex("#22c55e")},{320,Color3.fromHex("#84cc16")},{210,Color3.fromHex("#eab308")},{105,Color3.fromHex("#f97316")},{0,Color3.fromHex("#ef4444")}}
local EH,EL={},{}
local function GDC(d) for _,r in ipairs(DistC) do if d>=r[1] then return r[2] end end end
local function GEP(e)
    if e:IsA("Model") then
        if e.PrimaryPart then return e.PrimaryPart.Position end
        if e:FindFirstChild("HumanoidRootPart") then return e.HumanoidRootPart.Position end
        if e:FindFirstChild("Torso") then return e.Torso.Position end
    elseif e:IsA("BasePart") then return e.Position end
end

local function RefreshESP()
    if not _G[S].E then return end
    local et={}
    for _,c in ipairs(EP:GetChildren()) do if c:IsA("Model") or c:IsA("BasePart") then table.insert(et,c) end end
    local pp=HRP and HRP.Position; if not pp then return end
    
    local closestDistance = math.huge
    local closestMonster = nil
    
    for _,E in ipairs(et) do
        local pos=GEP(E); if not pos then continue end
        local d=(pos-pp).Magnitude; local c=GDC(d)
        local H=EH[E]
        if not H then
            H=Instance.new("Highlight");H.Name="ESP_H_"..S;H.Adornee=E;H.FillColor=c
            H.OutlineColor=Color3.fromRGB(235,235,235);H.FillTransparency=0.43
            H.OutlineTransparency=0;H.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop;H.Parent=E
            EH[E]=H
            local B=Instance.new("BillboardGui");B.Name="DistanceLabel";B.Size=UDim2.new(0,140,0,40)
            B.StudsOffset=Vector3.new(0,4,0);B.AlwaysOnTop=true;B.Parent=E
            local T=Instance.new("TextLabel");T.Name="DistanceText";T.Size=UDim2.new(1,0,1,0)
            T.BackgroundTransparency=1;T.TextSize=22;T.Font=Enum.Font.GothamBold
            T.TextStrokeTransparency=0;T.TextStrokeColor3=Color3.new(0,0,0);T.Parent=B
            EL[E]=B
        else H.FillColor=c end
        local T=EL[E] and EL[E]:FindFirstChild("DistanceText")
        if T then T.Text=string.format("%.1f m",d);T.TextColor3=c end
        
        -- 找到最近的怪物
        if d < closestDistance then
            closestDistance = d
            closestMonster = E
        end
    end
    
    -- 更新屏幕右下角距离显示（半透明，勉强可见）
    if ScreenDistanceGui and ScreenDistanceGui.Enabled and DistanceLabel then
        if closestMonster then
            DistanceLabel.Text = string.format("怪物: %.0f", closestDistance)
        else
            DistanceLabel.Text = "怪物: 无"
        end
    end
    
    for E in pairs(EH) do
        if not table.find(et,E) or not E.Parent then
            if EH[E] then EH[E]:Destroy() end
            if EL[E] then EL[E]:Destroy() end
            EH[E]=nil;EL[E]=nil
        end
    end
end

local function findStam()
    local m=ReplicatedStorage:FindFirstChild("Modules")
    if not m then return end
    local u=m:FindFirstChild("UIbased")
    if u and u:FindFirstChild("Stamina") and u.Stamina:FindFirstChild("Stamina") then
        return u.Stamina.Stamina
    end
end
local stamInst,stamConn=nil,nil
local function setStam(v)
    if v then
        stamInst=stamInst or findStam()
        if stamInst and not stamConn then
            stamConn=RunService.Heartbeat:Connect(function()
                if _G[S].Stamina then stamInst.Value=100 end
            end)
        end
    else if stamConn then stamConn:Disconnect() stamConn=nil end end
end

