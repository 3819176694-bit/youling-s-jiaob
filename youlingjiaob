-- ==================== 6. 实体透视（带距离颜色） ====================
local EP = workspace:FindFirstChild("Entities") or workspace
local DistColors = {
    {M=450, C=Color3.fromHex("#22c55e")},
    {M=320, C=Color3.fromHex("#84cc16")},
    {M=210, C=Color3.fromHex("#eab308")},
    {M=105, C=Color3.fromHex("#f97316")},
    {M=0,   C=Color3.fromHex("#ef4444")},
}
local EH = {}
local EL = {}

local function GetDistColor(D)
    for _, R in ipairs(DistColors) do
        if D >= R.M then return R.C end
    end
    return DistColors[#DistColors].C
end

local function GetEntityPos(E)
    if E:IsA("Model") then
        if E.PrimaryPart then return E.PrimaryPart.Position end
        if E:FindFirstChild("HumanoidRootPart") then return E.HumanoidRootPart.Position end
        if E:FindFirstChild("Torso") then return E.Torso.Position end
    elseif E:IsA("BasePart") then
        return E.Position
    end
    return nil
end

local function CreateHighlight(E)
    if EH[E] then return EH[E] end
    local H = Instance.new("Highlight")
    H.Name = "ESP_H_"..S
    H.Adornee = E
    H.FillColor = Color3.fromRGB(240,30,30)
    H.OutlineColor = Color3.fromRGB(235,235,235)
    H.FillTransparency = 0.43
    H.OutlineTransparency = 0
    H.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    H.Parent = E
    EH[E] = H
    return H
end

local function CreateLabel(E)
    if EL[E] then return EL[E] end
    local B = Instance.new("BillboardGui")
    B.Name = "DistanceLabel"
    B.Size = UDim2.new(0, 140, 0, 40)
    B.StudsOffset = Vector3.new(0, 4, 0)
    B.AlwaysOnTop = true
    local T = Instance.new("TextLabel")
    T.Name = "DistanceText"
    T.Size = UDim2.new(1,0,1,0)
    T.BackgroundTransparency = 1
    T.TextSize = 22
    T.Font = Enum.Font.GothamBold
    T.TextStrokeTransparency = 0
    T.TextStrokeColor3 = Color3.new(0,0,0)
    T.Parent = B
    B.Parent = E
    EL[E] = B
    return B
end

local function CleanEntities(C)
    for E, _ in pairs(EH) do
        if not table.find(C, E) or not E.Parent then
            if EH[E] then EH[E]:Destroy(); EH[E] = nil end
            if EL[E] then EL[E]:Destroy(); EL[E] = nil end
        end
    end
end

local function RefreshEntityESP()
    if not _G[S].E then return end
    if not EP then return end

    local ET = {}
    for _, C in ipairs(EP:GetChildren()) do
        if C:IsA("Model") or C:IsA("BasePart") then table.insert(ET, C) end
    end

    local PP = P.Character and P.Character:FindFirstChild("HumanoidRootPart") and P.Character.HumanoidRootPart.Position
    for _, E in ipairs(ET) do
        local Pos = GetEntityPos(E)
        if Pos and PP then
            local D = (Pos - PP).Magnitude
            local C = GetDistColor(D)
            local H = CreateHighlight(E)
            H.FillColor = C
            H.OutlineColor = Color3.fromRGB(235,235,235)
            local L = CreateLabel(E)
            local T = L:FindFirstChild("DistanceText")
            if T then
                T.Text = string.format("%.1f m", D)
                T.TextColor3 = C
            end
        end
    end
    CleanEntities(ET)
end

task.spawn(function()
    while _G[S].Running do
